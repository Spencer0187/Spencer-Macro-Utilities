#!/usr/bin/env bash
set -euo pipefail
HERE="$(dirname "$(readlink -f "$0")")"
export APPDIR="$HERE"
export SMU_APPDIR="$HERE"
export LD_LIBRARY_PATH="$HERE/usr/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"

NETHELPER_TMP="/tmp/nethelper-$USER"

if ! pgrep -x "nethelper-$USER" >/dev/null 2>&1; then
  rm -f "$NETHELPER_TMP"
  cp "$HERE/usr/bin/nethelper" "$NETHELPER_TMP"
  chmod +x "$NETHELPER_TMP"
  pkexec "$NETHELPER_TMP" &
fi

exec "$HERE/usr/bin/suspend" "$@"
