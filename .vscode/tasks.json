{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Configure Windows MSVC Debug",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--preset",
        "windows-msvc-debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Build Windows MSVC Debug",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "--preset",
        "windows-msvc-debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build"
      },
      "dependsOn": "Configure Windows MSVC Debug",
      "problemMatcher": "$msCompile"
    },
    {
